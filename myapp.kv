BoxLayout:
	canvas.before:
		Color:
			rgba: (0.1, 0.1, 0.6, 0.7)
		Rectangle:
			size: self.size
			pos: self.pos
	
	orientation: 'vertical'
	padding: 20
	spacing: 10
	
	BoxLayout:
		padding: 20
		spacing: 20
		size_hint_y: None
		height: 100
		
		Label:
			text: "Debt holder"
			font_size: "30sp"
			
		
	ScrollView:
		BoxLayout:
			id: list_container
			orientation: 'vertical'
			spacing: 20
			size_hint_y: None
			height: self.minimum_height
	
	FloatLayout:
		RoundedButton:		    		
	        text: "+"
	        font_size: "32sp"
	        size_hint: None, None
	        size: dp(64), dp(64)
	        pos_hint: {"center_x": .5, "y": .03}
	        rad: self.height/2
	        on_press: app.open_add_popup()
	
	
				
		

# A popup that appears when adding a new debt
# Is a class
<AddDebtPopup@ModalView>:
	# When the background is touched,
	# it closes the popup
	auto_dismiss: True
	on_dismiss: app.schedule_reset_popup(app.reset_add_popup)
	size_hint: .9, None
	height: "180dp"
	background: ""
	background_color: (0, 0, 0, 0)
	
	canvas.before:
		Color:
			rgba: (0.3, 0.3, 0.9, 0.6)
		RoundedRectangle:
			size: self.size
			pos: self.pos
			radius: [12]
	
	BoxLayout:
		orientation: 'vertical'
		spacing: "5dp"
		padding: "10dp"
		size_hint_y: None
		height: '140dp'
		
		Label:
			id: add_popup_label
			text: "Add a new debt owner."
			font_size: "20sp"
		
		BoxLayout:
			padding: 5
			spacing: 10
				
			TextInput:
				id: name_input
				hint_text: 'Name'
				multiline: False
				size_hint_y: None
				height: '30dp'
				padding: ["5dp", (self.height-self.line_height)/2]
				font_size: "18sp"
			
			TextInput:
				id: debt_input
				hint_text: 'Debt amount'
				multiline: False
				size_hint_y: None
				height: '30dp'
				padding: ["5dp", (self.height-self.line_height)/2]
				font_size: "18sp"
				input_filter: "float"
			
		RoundedButton:
			id: submit_button
			text: 'Add'
			font_size: "20sp"
			size_hint_y: None
			height: '40dp'
			bg_color: (0.5, 0.5, 0.9, 1)
			on_press: app.add_debt()

<RoundedButton@Button>
	bg_color: (0.2, 0.8, 0.3, 0.7)
	rad: 18
	
	background_normal: ""
	background_color: (0, 0, 0, 0)
	
	canvas.before:
		Color:
			rgba: root.bg_color
		RoundedRectangle:
			size: self.size
			pos: self.pos
			radius: [root.rad]